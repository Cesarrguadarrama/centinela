# =============================================================
# Centinela — environment configuration
# Copy to .env and adjust. docker-compose reads this file.
# =============================================================

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Host-side port mapping (change if you run a local Postgres on 5432)
POSTGRES_HOST_PORT=5432
POSTGRES_DB=centinela
POSTGRES_USER=centinela
POSTGRES_PASSWORD=centinela_dev_password

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
# Host-side port mapping (change if you run a local Redis on 6379)
REDIS_HOST_PORT=6379

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_TRANSACTIONS=spei.transactions
KAFKA_CONSUMER_GROUP=centinela-detection

# --- Backend (detection engine + REST API) ---
BACKEND_PORT=8080

# --- Transaction generator ---
GENERATOR_PORT=8081
# Modes: idle | normal | attack (phase 1+)
GENERATOR_MODE=idle
GENERATOR_TPS=10

# --- Frontend ---
FRONTEND_PORT=4200
